{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SoftwareServicesContract",
  "type": "object",
  "properties": {
    "effective_date": { "type": "string", "description": "ISO 8601: YYYY-MM-DD" },
    "service_provider": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "ein": { "type": "string" }
      }
    },
    "client": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "ein": { "type": "string" }
      }
    },
    "services": {
      "type": "array",
      "items": { "type": "string" }
    },
    "term_months": { "type": "integer" },
    "termination_date": { "type": "string", "description": "ISO 8601: YYYY-MM-DD" },
    "fees": {
      "type": "object",
      "properties": {
        "implementation_fee_usd": { "type": "number" },
        "annual_license_fee_usd": { "type": "number" },
        "monthly_support_retainer_usd": { "type": "number" },
        "late_payment_rate_monthly_percent": { "type": "number" },
        "currency": { "type": "string" }
      }
    },
    "governing_law_state": { "type": "string" },
    "dispute_resolution": { "type": "string" },
    "termination_notice_days": { "type": "integer" },
    "termination_for_cause_notice_days": { "type": "integer" },
    "confidentiality_period_years": { "type": "integer" },
    "signatories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "party": { "type": "string" },
          "name": { "type": "string" },
          "title": { "type": "string" },
          "date": { "type": "string" }
        }
      }
    }
  },
  "required": ["effective_date", "service_provider", "client", "fees", "term_months"]
}
